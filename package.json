{
  "name": "cicd-pipeline-template-app",
  "version": "0.1.0",
  "private": true,
  "description": "Reference application for the reusable CI/CD pipeline template.",
  "license": "Apache-2.0",
  "main": "app/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node app/index.js",
    "dev": "node --watch app/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"**/*.{js,json}\"",
    "format": "prettier --write \"**/*.{js,json}\"",
    "test": "JEST_JUNIT_OUTPUT_NAME=junit-unit.xml jest --selectProjects unit",
    "test:integration": "JEST_JUNIT_OUTPUT_NAME=junit-integration.xml jest --selectProjects integration --runInBand",
    "build": "node scripts/build.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  }
}
