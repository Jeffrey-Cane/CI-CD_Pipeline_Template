# Copy to .env and fill in values. NEVER commit your real .env.

# Application
APP_NAME=myapp
APP_PORT=8080

# Database (compose: postgres service)
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=appdb

# Cache (compose: redis service)
REDIS_URL=redis://redis:6379

# Container registry (used by the publish stage)
REGISTRY_USERNAME=
REGISTRY_TOKEN=

# Notifications (used by the notify stage)
NOTIFY_WEBHOOK=
